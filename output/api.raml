{
  "id": "your_order_id",
  "customer": {
    "id": "your_customer_id",
    "email": "customer@example.com",
    "firstName": "John",
    "lastName": "Doe"
  },
  "items": [
    {
      "productId": "your_product_id",
      "variantId": "your_variant_id",
      "quantity": 2,
      "price": 19.99
    },
    {
      "productId": "your_product_id",
      "variantId": "your_variant_id",
      "quantity": 1,
      "price": 9.99
    }
  ],
  "totalAmount": 29.98,
  "currency": "USD",
  "status": "pending"
}

