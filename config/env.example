# Provider selection: openai (default) or ollama
LLM_PROVIDER=openai

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Model Configuration
# Available models: gpt-4, gpt-4-turbo, gpt-3.5-turbo, etc.
OPENAI_MODEL=gpt-3.5-turbo

# Ollama (open-source local LLM) Configuration
# Install: https://ollama.com/download
# After install, run: ollama pull llama3.1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# OpenRouter (many community/free/low-cost models via one API)
# Get a key: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Example models: meta-llama/llama-3.1-8b-instruct, mistralai/mixtral-8x7b-instruct
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
# Optional attribution headers
OPENROUTER_SITE=https://yourdomain.com
OPENROUTER_APP_NAME=MuleSoft Multi-Agent

# Optional: Response Configuration
MAX_TOKENS=1000
TEMPERATURE=0.7

